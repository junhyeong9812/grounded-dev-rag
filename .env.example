# local-llm 환경변수 예시 — 실제 값은 .env 로 복사해 채운다(.env 는 gitignore).
# 배포 위치별로 필요한 값만 두면 된다. 사설 IP(192.168.55.x)는 코드 기본값으로 충분.

# --- PostgreSQL (core/api/indexer/intel/projects 공통) ---
# core/docker-compose.yml 의 POSTGRES_PASSWORD 와 반드시 동일해야 한다.
PG_PW=CHANGE_ME
PG_HOST=192.168.55.9          # (선택) 기본값과 같으면 생략 가능

# --- Gmail 알림 (api) ---
GMAIL_USER=your@gmail.com     # 발신 계정
GMAIL_APP_PASSWORD=           # Gmail 앱 비밀번호(16자) — 필수, 비우면 알림만 비활성
ALERT_TO=your@example.com     # 수신 주소

# --- 어드민 / 학습 인증 (api) ---
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_ADMIN
STUDY_USER=jun
STUDY_PASS_HASH=              # bcrypt 해시(있으면)

# --- projects 배치 (선택) ---
GITHUB_TOKEN=                 # GitHub 레이트리밋 완화용(선택)
